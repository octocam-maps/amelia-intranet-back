# ============================================
# Base de datos
# ============================================
DATABASE_URL=postgresql://postgres:postgres@amelia-intranet-database:5432/postgres

# ============================================
# Aplicación
# ============================================
# dev, stage, prod
ENVIRONMENT=dev
SWAGGER_ENABLED=true

# ============================================
# CORS (orígenes permitidos del frontend)
# ============================================
CORS_ORIGINS=http://localhost:5173

# ============================================
# JWT interno (emitido tras verificar identidad de Google)
# ============================================
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_COOKIE_NAME=amelia_intranet_refresh_token
# /auth (NO /auth/refresh): el navegador solo manda la cookie a rutas que
# empiecen por este path. Con /auth/refresh, la cookie nunca llegaba a
# /auth/logout y el logout no podía revocar nada server-side (SOFT-2170).
REFRESH_TOKEN_COOKIE_PATH=/auth
# true en producción (HTTPS); false en local (HTTP)
REFRESH_TOKEN_COOKIE_SECURE=false

# ============================================
# Google OIDC (Sign in with Google / Workspace)
# ============================================
# Crear en https://console.cloud.google.com/apis/credentials
# 1. Crear un "OAuth 2.0 Client ID" de tipo "Web application".
# 2. Orígenes de JavaScript autorizados: http://localhost:5173 (dev) + dominio de prod.
# 3. Copiar el Client ID aquí (el frontend usa el mismo valor en VITE_GOOGLE_CLIENT_ID).
# 4. No se necesita Client Secret: el flujo usa Google Identity Services (id_token) en el
#    frontend; el backend solo VERIFICA el id_token contra las claves públicas de Google.
GOOGLE_CLIENT_ID=

# Dominios de Google Workspace considerados "internos" (CSV, sin espacios) —
# determinan quién es "interno". El claim `hd` del id_token (VERIFICADO por
# Google, NUNCA el sufijo del email) debe coincidir con alguno de estos
# dominios para asignar rol `empleado` automáticamente (el rol `administrador`
# solo se asigna a mano). Fuera de esta lista, el alta solo es posible vía
# `invitations` (externo-invitado).
# Retrocompatibilidad: si esta variable no está definida, se usa la singular
# histórica GOOGLE_WORKSPACE_HOSTED_DOMAIN (un solo dominio).
GOOGLE_WORKSPACE_HOSTED_DOMAINS=ameliahub.com,octocam-maps.com

# ============================================
# Email transaccional (SendGrid) — Fase 6, placeholder ya en Fase 1
# ============================================
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@ameliahub.com
FRONTEND_URL=http://localhost:5173

# ============================================
# Google Drive (documentos/nóminas, Fase 4 v2) — mock por defecto
# ============================================
# mock (default, en memoria, sin red) | google (real, requiere lo de abajo)
DRIVE_PROVIDER=mock

# Solo necesarias con DRIVE_PROVIDER=google:
# Carpeta raíz de Drive bajo la que viven las subcarpetas por empleado
# (nombre = email de cada empleado).
DRIVE_ROOT_FOLDER_ID=
# Cuenta de Workspace a impersonar (Domain-Wide Delegation) — necesaria para
# que el sync lea carpetas/archivos que RRHH coloca a mano en Drive.
DRIVE_IMPERSONATE_SUBJECT=
# Credenciales de la Service Account: una ruta a fichero JSON en disco, O el
# JSON completo inline (usar solo una de las dos).
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=
GOOGLE_SERVICE_ACCOUNT_KEY_JSON=

# Tamaño máximo por documento (MB) — acota subida manual y qué archivos
# concilia el sync automático.
DOCUMENTS_MAX_UPLOAD_MB=10

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=text

# Solo usados por run_server.py (Docker CMD); por defecto 0.0.0.0:8000
# HOST=0.0.0.0
# PORT=8000
# UVICORN_RELOAD=true
