# ============================================
# Base de datos
# ============================================
DATABASE_URL=postgresql://postgres:postgres@amelia-intranet-database:5432/postgres

# ============================================
# Aplicación
# ============================================
# dev, stage, prod
ENVIRONMENT=dev
SWAGGER_ENABLED=true

# ============================================
# CORS (orígenes permitidos del frontend)
# ============================================
CORS_ORIGINS=http://localhost:5173

# ============================================
# JWT interno (emitido tras verificar identidad de Google)
# ============================================
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_COOKIE_NAME=amelia_intranet_refresh_token
REFRESH_TOKEN_COOKIE_PATH=/auth/refresh
# true en producción (HTTPS); false en local (HTTP)
REFRESH_TOKEN_COOKIE_SECURE=false

# ============================================
# Google OIDC (Sign in with Google / Workspace)
# ============================================
# Crear en https://console.cloud.google.com/apis/credentials
# 1. Crear un "OAuth 2.0 Client ID" de tipo "Web application".
# 2. Orígenes de JavaScript autorizados: http://localhost:5173 (dev) + dominio de prod.
# 3. Copiar el Client ID aquí (el frontend usa el mismo valor en VITE_GOOGLE_CLIENT_ID).
# 4. No se necesita Client Secret: el flujo usa Google Identity Services (id_token) en el
#    frontend; el backend solo VERIFICA el id_token contra las claves públicas de Google.
GOOGLE_CLIENT_ID=

# Dominio Google Workspace de la organización — determina quién es "interno".
# El claim `hd` del id_token debe coincidir con este valor para asignar rol
# `empleado`/`administrador` automáticamente. Fuera de este dominio, el alta
# solo es posible vía `invitations` (externo-invitado).
GOOGLE_WORKSPACE_HOSTED_DOMAIN=ameliahub.com

# ============================================
# Email transaccional (SendGrid) — Fase 6, placeholder ya en Fase 1
# ============================================
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@ameliahub.com
FRONTEND_URL=http://localhost:5173

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=text

# Solo usados por run_server.py (Docker CMD); por defecto 0.0.0.0:8000
# HOST=0.0.0.0
# PORT=8000
# UVICORN_RELOAD=true
